rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userData() {
      return get(/databases/$(database)/documents/employees/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() &&
        (request.auth.token.admin == true ||
          (exists(/databases/$(database)/documents/employees/$(request.auth.uid)) &&
           userData().role == 'ADMIN'));
    }

    function isString(v) {
      return v is string;
    }

    function isNumber(v) {
      return v is int || v is float;
    }

    function validTaskStatus(status) {
      return status in ['Pending', 'In Progress', 'Completed', 'Reviewed', 'Overdue', 'Cancelled'];
    }

    function validEmployeeSchema(data) {
      return data.keys().hasAll(['id', 'name', 'role', 'department', 'joining_date', 'email', 'contact']) &&
        isString(data.id) &&
        isString(data.name) &&
        isString(data.role) &&
        isString(data.department) &&
        isString(data.joining_date) &&
        isString(data.email) &&
        isString(data.contact);
    }

    function validTaskSchema(data) {
      return data.keys().hasAll(['id', 'employee_id', 'description', 'status', 'deadline', 'assigned_date', 'priority']) &&
        isString(data.id) &&
        isString(data.employee_id) &&
        isString(data.description) &&
        isString(data.status) &&
        validTaskStatus(data.status) &&
        isString(data.deadline) &&
        isString(data.assigned_date) &&
        isString(data.priority);
    }

    function validPerformanceSchema(data) {
      return data.keys().hasAll([
        'id',
        'employee_id',
        'date',
        'quality_score',
        'timeliness_score',
        'attendance_score',
        'communication_score',
        'innovation_score',
        'overall_rating',
        'remarks'
      ]) &&
      isString(data.id) &&
      isString(data.employee_id) &&
      isString(data.date) &&
      isNumber(data.quality_score) &&
      isNumber(data.timeliness_score) &&
      isNumber(data.attendance_score) &&
      isNumber(data.communication_score) &&
      isNumber(data.innovation_score) &&
      isNumber(data.overall_rating) &&
      isString(data.remarks);
    }

    function validAttendanceSchema(data) {
      return data.keys().hasAll(['id', 'employee_id', 'date', 'status']) &&
        isString(data.id) &&
        isString(data.employee_id) &&
        isString(data.date) &&
        isString(data.status);
    }

    match /employees/{employeeId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && validEmployeeSchema(request.resource.data);
      allow delete: if isAdmin();
    }

    match /tasks/{taskId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && validTaskSchema(request.resource.data);
      allow delete: if isAdmin();
    }

    match /performance/{reviewId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && validPerformanceSchema(request.resource.data);
      allow delete: if isAdmin();
    }

    match /attendance/{attendanceId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && validAttendanceSchema(request.resource.data);
      allow delete: if isAdmin();
    }

    match /departments/{departmentId} {
      allow read, create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /documents/{documentId} {
      allow read, create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read, create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
