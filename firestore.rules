rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/employees/$(request.auth.uid)).data;
    }
    
    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    // Employees Collection
    match /employees/{employeeId} {
      allow read: if isSignedIn() && (
        request.auth.uid == employeeId || 
        hasRole('ADMIN') || 
        (hasRole('LEAD') && getUserData().department == resource.data.department)
      );
      allow write: if hasRole('ADMIN');
      allow update: if isSignedIn() && request.auth.uid == employeeId && 
                    (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['profileImageUrl', 'phone']));
    }

    // Tasks Collection
    match /tasks/{taskId} {
      allow read: if isSignedIn() && (
        resource.data.assignedTo == request.auth.uid || 
        resource.data.assignedBy == request.auth.uid ||
        hasRole('ADMIN') ||
        (hasRole('LEAD') && get(/databases/$(database)/documents/employees/$(resource.data.assignedTo)).data.department == getUserData().department)
      );
      allow create: if hasRole('ADMIN') || hasRole('LEAD');
      allow update: if isSignedIn() && (
        resource.data.assignedTo == request.auth.uid || 
        resource.data.assignedBy == request.auth.uid ||
        hasRole('ADMIN')
      );
      allow delete: if hasRole('ADMIN');
    }

    // Performance Reviews Collection
    match /performance_reviews/{reviewId} {
      allow read: if isSignedIn() && (
        resource.data.employeeId == request.auth.uid || 
        hasRole('ADMIN') ||
        (hasRole('LEAD') && get(/databases/$(database)/documents/employees/$(resource.data.employeeId)).data.department == getUserData().department)
      );
      allow create: if hasRole('ADMIN') || hasRole('LEAD');
      allow update: if hasRole('ADMIN') || (hasRole('LEAD') && resource.data.reviewerId == request.auth.uid);
      allow delete: if hasRole('ADMIN');
    }

    // Notifications Collection
    match /notifications/{notificationId} {
      allow read, update, delete: if isSignedIn() && resource.data.recipientId == request.auth.uid;
      allow create: if isSignedIn();
    }
  }
}
