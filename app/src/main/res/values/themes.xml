<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.EmployeeTracker" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#FF9800</item> <!-- Vibrant Orange -->
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.EmployeeTracker</item>
    </style>
</resources>
